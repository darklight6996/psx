# PSX Advisory Agent v3 — Environment Config

# ── OPTIONAL: Claude API (Chairman only — minimises cost) ────────────────────
# Without this key, a local Ollama model chairs instead (100% free)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL: NewsAPI for Pakistan macro headlines ───────────────────────────
# NEWSAPI_KEY=your_newsapi_key_here

# ── Ollama server ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── App paths ─────────────────────────────────────────────────────────────────
PORTFOLIO_FILE=data/portfolio.json
MEMORY_FILE=data/memory_store.json
CACHE_DIR=data/cache
