# PSX Advisory Agent v3 — Environment Config
# Copy to .env: Windows: copy .env.example .env | Linux: cp .env.example .env

# ── OPTIONAL: Claude API (Chairman only — minimises cost) ────────────────────
# Free trial at: https://console.anthropic.com
# Without this key, a local Ollama model chairs instead (100% free)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL: NewsAPI for Pakistan macro headlines ───────────────────────────
# Free 100 req/day at: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# ── Ollama server (change only if Ollama runs on another machine) ────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── App paths (don't change unless you know what you're doing) ───────────────
PORTFOLIO_FILE=data/portfolio.json
MEMORY_FILE=data/memory_store.json
CACHE_DIR=data/cache
